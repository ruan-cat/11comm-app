# lock 文件还是不要了，我主要的版本写死就好了
pnpm-lock.yaml
# package-lock.json

# TIPS：如果某些文件已经加入了版本管理，现在重新加入 .gitignore 是不生效的，需要执行下面的操作
# `git rm -r --cached .` 然后提交 commit 即可。

# git rm -r --cached file1 file2  ## 针对某些文件
# git rm -r --cached dir1 dir2  ## 针对某些文件夹
# git rm -r --cached .  ## 针对所有文件

# 更新 uni-app 官方版本
# npx @dcloudio/uvm@latest

# 忽略掉 @chongdashu/cc-statusline 产生的日志
.claude/statusline.log

# 忽略本地缓存目录
local_cache/

# 项目内本地 git worktree 目录，用于隔离依赖升级与构建实验。
# 优先使用 `.worktrees/`；同时保留 `worktrees/` 作为历史兜底目录并一并忽略。
.worktrees/
worktrees/

# 忽略 vite 生成的缓存目录
.tmp-wot