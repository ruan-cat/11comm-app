{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build:h5:prod": {
      "cache": true,
      "outputs": ["dist/**"]
    },
    "build:nitro": {
      "cache": true,
      "outputs": [".output/**"]
    },
    "build:nitro:node": {
      "cache": true,
      "outputs": [".output/**"]
    },
    "build:nitro:vercel": {
      "cache": true,
      "outputs": [".output/**", ".vercel/output/**"]
    },
    "docs:build": {
      "cache": true,
      "outputs": ["docs/.vitepress/dist/**"]
    },
    "do-build": {
      "cache": true,
      "dependsOn": ["build:h5:prod", "build:nitro:vercel"]
    }
  }
}
